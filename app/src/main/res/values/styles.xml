<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Bharat Digital Protocol: Input Field Style -->
    <style name="Widget.CACI.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/caci_input_bg</item>
        <item name="boxStrokeColor">@color/caci_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/caci_primary</item>
        <item name="android:textColorHint">@color/caci_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CACI.Field</item>
    </style>

    <style name="ShapeAppearance.CACI.Field" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <!-- Bharat Digital Protocol: Primary Button — Navy Blue, 4dp radius -->
    <style name="Widget.CACI.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/caci_on_primary</item>
        <item name="backgroundTint">@color/caci_primary</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Bharat Digital Protocol: Secondary Button — Navy outline, transparent bg -->
    <style name="Widget.CACI.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/caci_primary</item>
        <item name="cornerRadius">4dp</item>
        <item name="strokeColor">@color/caci_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Exposed Dropdown Menu Style -->
    <style name="Widget.CACI.ExposedDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/caci_input_bg</item>
        <item name="boxStrokeColor">@color/caci_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/caci_primary</item>
        <item name="android:textColorHint">@color/caci_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CACI.Field</item>
    </style>

</resources>
