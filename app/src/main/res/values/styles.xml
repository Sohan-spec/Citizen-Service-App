<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ─── Bharat Digital Protocol: Redesigned Styles ─── -->

    <!-- Filled Input Field — Rounded, gray fill, modern feel -->
    <style name="Widget.CACI.InputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/caci_input_bg_new</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="hintTextColor">@color/caci_secondary</item>
        <item name="android:textColorHint">@color/caci_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CACI.Field</item>
        <item name="startIconTint">@color/caci_hint</item>
    </style>

    <style name="ShapeAppearance.CACI.Field" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Primary Button — Saffron gradient, fully rounded -->
    <style name="Widget.CACI.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/caci_secondary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- Secondary Button — Navy outline, transparent bg, rounded -->
    <style name="Widget.CACI.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/caci_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/caci_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Green Action Button — for View as Resident etc. -->
    <style name="Widget.CACI.GreenButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/caci_tertiary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Exposed Dropdown — Rounded, matching input style -->
    <style name="Widget.CACI.ExposedDropdown" parent="Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/caci_input_bg_new</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/caci_secondary</item>
        <item name="android:textColorHint">@color/caci_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CACI.Field</item>
    </style>

    <!-- Locality Card Shape — 12dp rounded -->
    <style name="ShapeAppearance.CACI.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>
