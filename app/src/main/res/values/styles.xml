<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.CACI.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/caci_input_bg</item>
        <item name="boxStrokeColor">@color/caci_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/caci_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CACI.Field</item>
    </style>

    <style name="ShapeAppearance.CACI.Field" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="Widget.CACI.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/caci_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.CACI.SecondaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/caci_primary</item>
        <item name="backgroundTint">@color/caci_surface</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/caci_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
