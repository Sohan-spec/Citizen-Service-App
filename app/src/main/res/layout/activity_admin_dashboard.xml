<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caci_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/caci_primary"
        android:minHeight="?attr/actionBarSize"
        android:title="@string/water_dashboard_title"
        android:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert" />

    <!-- Tricolor Stripe -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/caci_secondary" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/white" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/caci_tertiary" />
    </LinearLayout>

    <!-- Officer subtitle -->
    <TextView
        android:id="@+id/textOfficerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textColor="@color/caci_text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMySchedules"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/my_schedules"
            android:textColor="@color/caci_primary"
            android:textSize="12sp"
            app:strokeColor="@color/caci_primary"
            app:cornerRadius="4dp"
            app:icon="@drawable/ic_water_drop"
            app:iconSize="16dp"
            app:iconTint="@color/caci_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonViewAsResident"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/view_as_resident"
            android:textColor="@color/caci_tertiary"
            android:textSize="12sp"
            app:strokeColor="@color/caci_tertiary"
            app:cornerRadius="4dp"
            app:icon="@drawable/ic_resident_user"
            app:iconSize="16dp"
            app:iconTint="@color/caci_tertiary" />
    </LinearLayout>

    <!-- Locality Cards Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardKoramangala"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Water" android:src="@drawable/ic_water_drop" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_koramangala" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardIndiranagar"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Water" android:src="@drawable/ic_water_drop" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_indiranagar" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWhitefield"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Water" android:src="@drawable/ic_water_drop" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_whitefield" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJayanagar"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Water" android:src="@drawable/ic_water_drop" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_jayanagar" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHSR"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="Water" android:src="@drawable/ic_water_drop" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_hsr" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrentLocation"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="4dp"
                app:strokeColor="@color/caci_border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="14dp">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="GPS" android:src="@drawable/ic_gps_location" />
                    <TextView android:id="@+id/textCurrentLocality" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/locality_current" android:textColor="@color/caci_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Map Container -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp" />

</LinearLayout>
